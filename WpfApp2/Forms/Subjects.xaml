<Page x:Class="WpfApp2.Subjects"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp2"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="900" MinHeight="600" MinWidth="800"
      Title="Управление данными" 
      Loaded="Page_Loaded"
      Background="White">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок страницы -->
        <Border Grid.Row="0" Background="#090974" Height="80" CornerRadius="0,0,20,20">
            <TextBlock Text="Управление данными" 
                       FontSize="24" FontWeight="SemiBold" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Таблица с данными -->
        <DataGrid x:Name="DataGrid" Grid.Row="1" Margin="40,30,40,20" 
                  BorderBrush="#090974"
          AutoGenerateColumns="True" 
          AutoGeneratingColumn="DataGrid_AutoGeneratingColumn"
          CellEditEnding="DataGrid_CellEditEnding"
          RowEditEnding="DataGrid_RowEditEnding"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          CanUserReorderColumns="True"
          CanUserResizeColumns="True"
          CanUserSortColumns="True"
          AlternatingRowBackground="#F9F9F9"
          RowHeight="35"
          FontSize="14">
        </DataGrid>

        <!-- Нижняя панель с элементами управления -->
        <Grid Grid.Row="2" Margin="40,0,40,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель - выбор типа данных -->
            <StackPanel Grid.Column="0" x:Name="SelectStack" Orientation="Horizontal" 
                        VerticalAlignment="Center" HorizontalAlignment="Left">
                <TextBlock FontFamily="Arial" FontWeight="SemiBold" FontSize="18" 
                           Foreground="#090974" TextAlignment="Center" VerticalAlignment="Center">
                    Показать:
                </TextBlock>
                <ComboBox x:Name="DataTypeComboBox" Height="35" Width="150" 
                          Margin="15,0,0,0" 
                          FontSize="18" FontWeight="Normal" Foreground="#090974"
                          SelectionChanged="DataTypeComboBox_SelectionChanged">
                    <ComboBoxItem Content="Предметы" IsSelected="True"/>
                    <ComboBoxItem Content="Учителя"/>
                    <ComboBoxItem Content="Ученики"/>
                    <ComboBoxItem Content="Классы"/>
                </ComboBox>
            </StackPanel>

            <!-- Правая панель - кнопки управления -->
            <StackPanel Grid.Column="1" x:Name="ButtonsStack" Orientation="Horizontal" 
                        HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBox x:Name="SearchText" Height="40" Width="150" FontSize="18" Foreground="#090974"/>
                <Button x:Name="SearchButton" Height="40" Width="40" Margin="0,0,15,0" Content="🔍" Style="{StaticResource LongButton}" local:ButtonStyleExtensions.NormalColor="#128C58" 
local:ButtonStyleExtensions.HoverColor="#47A27B" Click="SearchButton_Click"
local:ButtonStyleExtensions.PressedColor="#36D792" Foreground="White" FontSize="18"/>
                <Button x:Name="SaveButton" Height="40"  Width="150" 
                        Content="Сохранить" Style="{StaticResource LongButton}"
                        local:ButtonStyleExtensions.NormalColor="#128C58" 
                        local:ButtonStyleExtensions.HoverColor="#47A27B" 
                        local:ButtonStyleExtensions.PressedColor="#36D792"
                        Foreground="White" FontWeight="SemiBold" FontSize="14" 
                        Click="SaveButton_Click">
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>