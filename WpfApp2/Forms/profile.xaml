<Page x:Class="WpfApp2.profile"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp2"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="800" 
      Title="Профиль пользователя" 
      Loaded="Page_Loaded"
      Background="White">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок страницы -->
        <Border Grid.Row="0" Background="#090974" Height="100" CornerRadius="0,0,20,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="ProfileText" 
                           FontSize="24" 
                           FontWeight="SemiBold" 
                           Foreground="White">Профиль пользователя</TextBlock>
            </StackPanel>
        </Border>

        <!-- Основной контент -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="40,30,40,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>

                </Grid.RowDefinitions>

                <!-- Аватар -->
                <Border Grid.Row="0" Grid.ColumnSpan="2" 
                        Background="#F5F5F5" 
                        CornerRadius="60" 
                        Width="120" Height="120" 
                        HorizontalAlignment="Center" 
                        Margin="0,0,0,20">
                    <Viewbox Stretch="Uniform" Margin="25">
                        <Path Stroke="#090974" Fill="#E8F0FE">
                            <Path.Data>
                                <PathGeometry Figures="M12 4a5 5 0 1 1-5 5a5 5 0 0 1 5-5m0-2a7 7 0 1 0 7 7a7 7 0 0 0-7-7m10 28h-2v-5a5 5 0 0 0-5-5H9a5 5 0 0 0-5 5v5H2v-5a7 7 0 0 1 7-7h6a7 7 0 0 1 7 7zm0-26h10v2H22zm0 5h10v2H22zm0 5h7v2h-7z" FillRule="NonZero"/>
                            </Path.Data>
                        </Path>
                    </Viewbox>
                </Border>

                <!-- Разделитель -->
                <Border Grid.Row="1" Grid.ColumnSpan="2" 
                        Height="1" Background="#E0E0E0" 
                        Margin="0,0,0,20"/>

                <!-- Заголовок секции -->
                <TextBlock Grid.Row="2" Grid.ColumnSpan="2" 
                           Text="Основная информация" 
                           FontSize="18" FontWeight="SemiBold" 
                           Foreground="#090974" 
                           Margin="0,0,0,20"
                           HorizontalAlignment="Center"/>

                <!-- Имя -->
                <TextBlock Grid.Row="3" Grid.Column="0" 
                           Text="Имя:" 
                           FontSize="15" FontWeight="SemiBold" 
                           Foreground="#666666" 
                           VerticalAlignment="Center" 
                           Margin="0,10,10,10"/>
                <TextBlock Grid.Row="3" Grid.Column="1" 
                           x:Name="Name" 
                           FontSize="15" 
                           Text="Имя" 
                           Foreground="#090974"
                           VerticalAlignment="Center"
                           Margin="0,10,0,10"/>

                <!-- Роль -->
                <TextBlock Grid.Row="4" Grid.Column="0" 
                           Text="Роль:" 
                           FontSize="15" FontWeight="SemiBold" 
                           Foreground="#666666" 
                           VerticalAlignment="Center" 
                           Margin="0,10,10,10"/>
                <TextBlock Grid.Row="4" Grid.Column="1" 
                           x:Name="Role" 
                           FontSize="15" 
                           Text="Ученик" 
                           Foreground="#090974"
                           VerticalAlignment="Center"
                           Margin="0,10,0,10"/>

                <!-- Дисциплины (только для учителя) -->
                <TextBlock Grid.Row="5" Grid.Column="0" 
                           x:Name="SubjectsLabel"
                           Text="Дисциплины:" 
                           FontSize="15" FontWeight="SemiBold" 
                           Foreground="#666666" 
                           VerticalAlignment="Top" 
                           Margin="0,10,10,10"
                           Visibility="Collapsed"/>
                <TextBlock Grid.Row="5" Grid.Column="1" 
                           x:Name="Subjects" 
                           FontSize="14" 
                           Text="-" 
                           TextWrapping="Wrap" 
                           Foreground="#090974"
                           Margin="0,10,0,10"
                           Visibility="Collapsed"/>

                <!-- Разделитель -->
                <Border Grid.Row="6" Grid.ColumnSpan="2" 
                        Height="1" Background="#E0E0E0" 
                        Margin="0,20,0,20"/>

                <!-- Заголовок секции безопасности -->
                <TextBlock Grid.Row="7" Grid.ColumnSpan="2" 
                           Text="Безопасность" 
                           FontSize="18" FontWeight="SemiBold" 
                           Foreground="#090974" 
                           Margin="0,0,0,20"
                           HorizontalAlignment="Center"/>

                <!-- Логин -->
                <TextBlock Grid.Row="8" Grid.Column="0" 
                           Text="Логин:" 
                           FontSize="15" FontWeight="SemiBold" 
                           Foreground="#666666" 
                           VerticalAlignment="Center" 
                           Margin="0,10,10,10"/>
                <TextBlock Grid.Row="8" Grid.Column="1" 
                           x:Name="Login" 
                           FontSize="15" 
                           Text="login" 
                           Foreground="#090974"
                           VerticalAlignment="Center"
                           Margin="0,10,0,10"/>
                <TextBox Grid.Row="8" Grid.Column="1" 
                         x:Name="InputLogin" 
                         FontSize="14" Height="35" 
                         Padding="8,5"
                         Foreground="#090974" 
                         BorderBrush="#090974" 
                         BorderThickness="1"
                         HorizontalAlignment="Left" 
                         Width="250"
                         Visibility="Collapsed"
                         KeyDown="InputLogin_KeyDown"
                         VerticalAlignment="Center"/>

                <!-- Пароль -->
                <TextBlock Grid.Row="9" Grid.Column="0" 
                           Text="Пароль:" 
                           FontSize="15" FontWeight="SemiBold" 
                           Foreground="#666666" 
                           VerticalAlignment="Center" 
                           Margin="0,10,10,10"/>
                <TextBlock Grid.Row="9" Grid.Column="1" 
                           x:Name="Password" 
                           FontSize="15" 
                           Text="*****" 
                           Foreground="#090974"
                           VerticalAlignment="Center"
                           Margin="0,10,0,10"/>
                <PasswordBox Grid.Row="9" Grid.Column="1" 
                             x:Name="InputPass" 
                             FontSize="14" Height="35" 
                             Padding="8,5"
                             Foreground="#090974" 
                             BorderBrush="#090974" 
                             BorderThickness="1"
                             HorizontalAlignment="Left" 
                             Width="250"
                             Visibility="Collapsed"
                             PasswordChar="*"
                             KeyDown="InputPass_KeyDown"
                             VerticalAlignment="Center"/>

                <!-- Кнопка изменения данных -->
                <Button Grid.Row="10" Grid.ColumnSpan="2" 
                        x:Name="ChangeDataButton" 
                        Height="45" Width="250" 
                        Margin="0,30,0,20"
                        HorizontalAlignment="Center"
                        Style="{DynamicResource LongButton}"
                        local:ButtonStyleExtensions.NormalColor="#128C58" 
                        local:ButtonStyleExtensions.HoverColor="#47A27B" 
                        local:ButtonStyleExtensions.PressedColor="#36D792"
                        FontSize="16" FontWeight="SemiBold" 
                        Foreground="White" 
                        Click="ChangeDataButton_Click">
                    Изменить данные
                </Button>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>