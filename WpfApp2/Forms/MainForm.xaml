<Window x:Class="WpfApp2.MainForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2"
        mc:Ignorable="d"
        Title="Система учета успеваемости" 
        Height="700" Width="1100" MinHeight="650" MinWidth="1000"
        WindowStartupLocation="CenterScreen" 
        Closed="Window_Closed" 
        Loaded="Window_Loaded"
        Background="#F5F7FA">

    <Grid Background="#F5F7FA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#9ABEDA" CornerRadius="0,0,0,0" 
                BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <StackPanel Margin="0,30,0,20">
                <!-- Логотип/Заголовок -->
                <Border Background="#090974" Height="80" Margin="0,0,0,30" CornerRadius="0,20,20,0">
                    <TextBlock Text="Электронный журнал" 
                               FontSize="18" FontWeight="SemiBold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center"
                               Margin="10"/>
                </Border>

                <!-- Профиль пользователя -->
                <ToggleButton x:Name="ProfileButton" 
                              Style="{StaticResource NavToggleButton}" 
                              Click="Button_Click"
                              Margin="15,0,15,20"
                              Height="50"
                              HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Canvas Width="28" Height="28" Margin="0,0,10,0">
                            <Canvas.RenderTransform>
                                <TranslateTransform X="-11" Y="0"/>
                            </Canvas.RenderTransform>
                            <Path Fill="#1A1A8D">
                                <Path.Data>
                                    <PathGeometry Figures="M23.333 13.125a5.833 5.833 0 1 1-11.666 0a5.833 5.833 0 0 1 11.666 0m-2.917 0a2.917 2.917 0 1 1-5.833 0a2.917 2.917 0 0 1 5.833 0" FillRule="EvenOdd"/>
                                </Path.Data>
                            </Path>
                            <Path Fill="#1A1A8D">
                                <Path.Data>
                                    <PathGeometry Figures="M17.5 1.458C8.65 1.458 1.458 8.65 1.458 17.5c0 8.85 7.192 16.042 16.042 16.042c8.85 0 16.042-7.192 16.042-16.042C33.542 8.65 26.35 1.458 17.5 1.458M4.375 17.5c0 3.048 1.04 5.854 2.783 8.062a13.11 13.11 0 0 1 10.34-5.104a13.1 13.1 0 0 1 10.34 5.042A13.125 13.125 0 1 0 4.375 17.5m13.125 13.125a13.06 13.06 0 0 1-8.27-2.933a10.192 10.192 0 0 1 8.27-4.25a10.19 10.19 0 0 1 8.291 4.258A13.068 13.068 0 0 1 17.5 30.625" FillRule="EvenOdd"/>
                                </Path.Data>
                            </Path>
                        </Canvas>
                        <TextBlock Text="Профиль" FontSize="16" FontWeight="SemiBold" 
                                   Foreground="#090974" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>

                <!-- Разделитель -->
                <Rectangle Height="1" Fill="#E0E0E0" Margin="15,0,15,15"/>

                <!-- Кнопки навигации -->
                <ToggleButton x:Name="AllGradesButton" 
                              Content="Итоговые оценки" 
                              FontWeight="SemiBold" FontSize="14"
                              Click="AllGradesButton_Click" 
                              Style="{StaticResource NavToggleButton}"
                              Margin="15,5,15,5" 
                              Height="45" 
                              HorizontalAlignment="Stretch"/>

                <ToggleButton x:Name="DistGradeButton" 
                              Content="Успеваемость" 
                              FontWeight="SemiBold" FontSize="14"
                              Click="DistGradeButton_Click" 
                              Style="{StaticResource NavToggleButton}"
                              Margin="15,5,15,5" 
                              Height="45" 
                              HorizontalAlignment="Stretch"/>

                <ToggleButton x:Name="AppointButton" 
                              Content="Назначить"  
                              FontWeight="SemiBold" FontSize="14"
                              Click="AppointButton_Click" 
                              Style="{StaticResource NavToggleButton}"
                              Margin="15,5,15,5" 
                              Height="45" 
                              HorizontalAlignment="Stretch"/>

                <ToggleButton x:Name="AddButton" 
                              Content="Добавить" 
                              FontWeight="SemiBold" FontSize="14"
                              Click="AddButton_Click" 
                              Style="{StaticResource NavToggleButton}"
                              Margin="15,5,15,5" 
                              Height="45" 
                              HorizontalAlignment="Stretch"/>

                <!-- Разделитель -->
                <Rectangle Height="1" Fill="#E0E0E0" Margin="15,20,15,15"/>

                <!-- Кнопка инструкции внизу -->
                <ToggleButton x:Name="InfoButton" 
                              Content="Инструкция" 
                              FontSize="14" FontWeight="SemiBold" 
                              Margin="15,5,15,5" 
                              Click="InfoButton_Click" 
                              Style="{StaticResource NavToggleButton}" 
                              Height="45" 
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Bottom"/>
            </StackPanel>
        </Border>

        <!-- Основная область контента -->
        <Grid Grid.Column="1" Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Верхняя панель -->
            <Border Grid.Row="0" Background="#9ABEDA
" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                    Height="60">
                <Grid HorizontalAlignment="Right">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="Role" Grid.RowSpan="2" Grid.Column="1"
                               Text="Роль" 
                               FontSize="14" 
                               FontWeight="Normal" 
                               Foreground="#090974" 
                               VerticalAlignment="Center" 
                               HorizontalAlignment="Right"
                               Margin="0,0,20,0"/>
                    <TextBlock x:Name="Name" Grid.Column="0"
                       Text="Имя" 
                       FontSize="16" 
                       FontWeight="SemiBold" 
                       Foreground="#090974" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Center"
                       Margin="0,5,0,0"/>
                    <TextBlock x:Name="Class" Grid.Column="0" Grid.Row="1"
                       Text="Класс" 
                       FontSize="14" 
                       FontWeight="Normal" 
                       Foreground="#090974" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>
                </Grid>
            </Border>

            <!-- Frame для отображения страниц -->
            <Frame x:Name="View" 
                   Grid.Row="1" 
                   Background="#9ABEDA" 
                   NavigationUIVisibility="Hidden"
                   Margin="0,0,0,0"/>
        </Grid>
    </Grid>
</Window>