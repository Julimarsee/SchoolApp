<Window x:Class="WpfApp2.Autorization"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Title="Авторизация" Height="370" Width="700">
    <Grid>

            <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="80"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Image Grid.RowSpan="4" Source="/Source/background.jpg" Stretch="Fill"/>

        <TextBlock Grid.Column="1" Text="Войти" Margin="0,20,0,0" VerticalAlignment="Center" HorizontalAlignment="Center" TextBlock.FontSize="30" TextBlock.Foreground="#090974" FontWeight="SemiBold"/>

        <Viewbox Stretch="Uniform" Height ="35" MouseLeftButtonDown="Viewbox_MouseLeftButtonDown_1"
                 Width="35" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="15">
            <Canvas Width="24" Height="24">
                <Path Style="{StaticResource ChangeColor}">
                    <Path.Data>
                        <PathGeometry Figures="M12 1C5.925 1 1 5.925 1 12s4.925 11 11 11s11-4.925 11-11S18.075 1 12 1m-.5 5a1 1 0 1 0 0 2h.5a1 1 0 1 0 0-2zM10 10a1 1 0 1 0 0 2h1v3h-1a1 1 0 1 0 0 2h4a1 1 0 1 0 0-2h-1v-4a1 1 0 0 0-1-1z" FillRule="EvenOdd"/>
                    </Path.Data>
                </Path>
            </Canvas>
        </Viewbox>

        <StackPanel Grid.Column="1"  Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock  Text="Логин" FontSize="20" Foreground="#AFA79F" VerticalAlignment="Top" Margin="0,0,15,0"/>
            <StackPanel >
                <TextBox Name="loginText" TextWrapping="Wrap" Width="310" Height="30" BorderThickness="0" Foreground="#FF989898" FontSize="20"/>
                <Border BorderBrush="Silver" BorderThickness="3" Height="1" Width="310" />
            </StackPanel>
        </StackPanel>


        <StackPanel Grid.Column="1"  Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,15,0">
            <TextBlock  Text="Пароль" FontSize="20" Foreground="#AFA79F" VerticalAlignment="Top" Margin="30,0,15,0" />
            <StackPanel >
                <PasswordBox Name ="PassText" Width="310" Height="30" BorderThickness="0" Foreground="#FF989898" FontSize="20" PasswordChanged="PassText_PasswordChanged"/>
                <TextBox Name ="parolText" TextWrapping="Wrap" Width="310" Height="30" BorderThickness="0" Foreground="#FF989898" FontSize="20" Visibility="Collapsed" TextChanged="parolText_TextChanged"/>
                <Border BorderBrush="Silver" BorderThickness="3" Height="1" Width="310" />
                <TextBlock Name="Error" Foreground="#FF3C00" FontSize="15" VerticalAlignment="Bottom" HorizontalAlignment="Center" FontWeight="DemiBold"
                          Visibility="Visible">
                    <TextBlock Name="Err" Text="Введите" Visibility="Collapsed"/>
                    <TextBlock Name="IsParol" Text="пароль" Visibility="Collapsed"/>
                    <TextBlock Name="IsAll" Text="данные" Visibility="Collapsed"/>
                    <TextBlock Name="IsFalse" Text="Неправильный логин или пароль" Visibility="Collapsed"/>
                </TextBlock>
            </StackPanel>
            <TextBlock x:Name="MaskText" Text="➖" FontSize="25" Foreground="#033E6B" MouseLeftButtonDown="TextBlock_MouseLeftButtonDown"/>
        </StackPanel>


        <Button Grid.Column="1"  Grid.Row="3" Width="360" Height="50" Style="{StaticResource LongButton}" local:ButtonStyleExtensions.NormalColor="#3F92D2" 
                local:ButtonStyleExtensions.HoverColor="#0B61A4" local:ButtonStyleExtensions.PressedColor="#25567B" Content="Вход" FontWeight="SemiBold" Foreground="White"
                FontSize="24" VerticalAlignment="Top" Margin="15" Click="Button_Click_1" />
        <Viewbox Stretch="Uniform" Grid.Row="3" Width="35" HorizontalAlignment="Left" MouseLeftButtonDown="Viewbox_MouseLeftButtonDown"
                 Margin="15" VerticalAlignment="Bottom">
            <Canvas Width="24" Height="24">
                <Path Style="{StaticResource ChangeColor}">
                    <Path.Data>
                        <PathGeometry Figures="M10.09 15.59L11.5 17l5-5l-5-5l-1.41 1.41L12.67 11H3v2h9.67zM19 3H5a2 2 0 0 0-2 2v4h2V5h14v14H5v-4H3v4a2 2 0 0 0 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2" FillRule="EvenOdd"/>
                    </Path.Data>
                </Path>
            </Canvas>
        </Viewbox>
    </Grid>
</Window>
