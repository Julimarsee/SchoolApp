<Page x:Class="WpfApp2.newSub"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp2"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="900" 
      Title="Новая дисциплина" 
      Loaded="Page_Loaded"
      Background="White">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок страницы -->
        <Border Grid.Row="0" Background="#090974" Height="100" CornerRadius="0,0,20,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button x:Name="ReturnButton" 
                        Content="←" 
                        Height="40" 
                        Width="40" 
                        FontSize="24" 
                        FontWeight="Bold" 
                        Visibility="Collapsed"
                        Margin="0,0,20,0" 
                        Style="{DynamicResource LongButton}"
                        local:ButtonStyleExtensions.NormalColor="#128C58" 
                        local:ButtonStyleExtensions.HoverColor="#47A27B" 
                        local:ButtonStyleExtensions.PressedColor="#36D792"
                        Foreground="White"
                        Click="ReturnButton_Click"/>
                <TextBlock x:Name="NewSabText" 
                           FontSize="24" 
                           FontWeight="SemiBold" 
                           Foreground="White">Создание новой дисциплины</TextBlock>
            </StackPanel>
        </Border>

        <!-- Основная форма -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="40,30,40,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Название дисциплины -->
                <TextBlock Grid.Row="0" Grid.Column="0" 
                           Text="Название:" 
                           FontSize="16" FontWeight="SemiBold" 
                           Foreground="#090974" 
                           VerticalAlignment="Center" 
                           Margin="0,10,10,10"/>
                <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                         x:Name="Name" 
                         FontSize="14" Height="40" 
                         Padding="10,8"
                         Foreground="#090974" 
                         BorderBrush="#090974" 
                         BorderThickness="1"
                         TextChanged="Name_TextChanged"
                         VerticalAlignment="Center"/>

                <!-- Учителя -->
                <TextBlock Grid.Row="1" Grid.Column="0" 
                           Text="Учителя:" 
                           FontSize="16" FontWeight="SemiBold" 
                           Foreground="#090974" 
                           VerticalAlignment="Center" 
                           Margin="0,10,10,10"/>
                <ComboBox Grid.Row="1" Grid.Column="1" 
                          x:Name="Teachers" 
                          FontSize="14" Height="40"
                          Foreground="#090974" 
                          BorderBrush="#090974" 
                          BorderThickness="1"
                          SelectionChanged="Teachers_SelectionChanged"
                          VerticalAlignment="Center"/>
                <Button Grid.Row="1" Grid.Column="2" 
                        x:Name="Add" 
                        Content="+" 
                        FontWeight="Bold" 
                        Width="40" Height="40" 
                        Margin="10,0,0,0"
                        Style="{DynamicResource LongButton}"
                        local:ButtonStyleExtensions.NormalColor="#3F92D2" 
                        local:ButtonStyleExtensions.HoverColor="#0B61A4" 
                        local:ButtonStyleExtensions.PressedColor="#25567B"
                        Foreground="White"
                        FontSize="20"
                        Click="Add_Click"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"/>

                <!-- Кнопка Новый учитель -->
                <Button Grid.Row="2" Grid.Column="1" 
                        x:Name="newProf" 
                        Width="200" Height="40" 
                        Margin="0,5,0,5" 
                        HorizontalAlignment="Left"
                        Style="{DynamicResource LongButton}"
                        local:ButtonStyleExtensions.NormalColor="#3F92D2" 
                        local:ButtonStyleExtensions.HoverColor="#0B61A4" 
                        local:ButtonStyleExtensions.PressedColor="#25567B"
                        Foreground="White" 
                        FontWeight="SemiBold" 
                        FontSize="14" 
                        Click="newProf_Click"
                        VerticalAlignment="Center">
                    Новый учитель
                </Button>

                <!-- Специальность -->
                <TextBlock Grid.Row="3" Grid.Column="0" 
                           Text="Класс:" 
                           FontSize="16" FontWeight="SemiBold" 
                           Foreground="#090974" 
                           VerticalAlignment="Center" 
                           Margin="0,10,10,10"/>
                <ComboBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                          x:Name="Groups" 
                          FontSize="14" Height="40"
                          Foreground="#090974" 
                          BorderBrush="#090974" 
                          BorderThickness="1"
                          VerticalAlignment="Center"/>

                <!-- Чекбокс зачета (скрыт в новой версии) -->
                <TextBlock Grid.Row="4" Grid.Column="0" 
                           x:Name="OffsetLabel"
                           Text="Только зачет?:" 
                           FontSize="16" FontWeight="SemiBold" 
                           Foreground="#090974" 
                           VerticalAlignment="Center" 
                           Margin="0,10,10,10"
                           Visibility="Collapsed"/>
                <CheckBox Grid.Row="4" Grid.Column="1" 
                          x:Name="IsOffset" 
                          Margin="0,10,0,0"
                          BorderBrush="#090974" 
                          BorderThickness="2"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          Height="25"
                          Visibility="Collapsed"/>

                <!-- Сообщение об ошибке -->
                <TextBlock Grid.Row="5" Grid.ColumnSpan="3" 
                           x:Name="Error" 
                           FontSize="14" 
                           Margin="0,15,0,0" 
                           Foreground="#D93D0C" 
                           TextAlignment="Center"
                           Text="Все поля должны быть заполнены" 
                           TextWrapping="Wrap" 
                           Visibility="Collapsed"
                           HorizontalAlignment="Center"/>
            </Grid>
        </ScrollViewer>

        <!-- Кнопка сохранения -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Button x:Name="Save" 
                    Width="300" Height="50" 
                    Margin="15,20,15,20"
                    Style="{StaticResource LongButton}"
                    local:ButtonStyleExtensions.NormalColor="#128C58" 
                    local:ButtonStyleExtensions.HoverColor="#47A27B" 
                    local:ButtonStyleExtensions.PressedColor="#36D792"
                    Foreground="White" FontWeight="SemiBold" FontSize="18" 
                    Click="Save_Click"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Center">
                Создать дисциплину
            </Button>
        </Border>
    </Grid>
</Page>