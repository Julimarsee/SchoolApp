<Page x:Class="WpfApp2.newProf"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp2"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="900" 
      Loaded="Page_Loaded"
      Title="Новый профиль"
      Background="White">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок страницы -->
        <Border Grid.Row="0" Background="#090974" Height="100" CornerRadius="0,0,20,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button x:Name="ReturnButton" Content="←" Height="40" Width="40" FontSize="24" 
                        FontWeight="Bold" Visibility="Collapsed"
                        Margin="0,0,20,0" Style="{DynamicResource LongButton}" 
                        local:ButtonStyleExtensions.NormalColor="#128C58" 
                        local:ButtonStyleExtensions.HoverColor="#47A27B" 
                        local:ButtonStyleExtensions.PressedColor="#36D792" 
                        Foreground="White" Click="ReturnButton_Click"/>
                <TextBlock x:Name="NewSabText" 
                           FontSize="24" FontWeight="SemiBold" 
                           Foreground="White">Создание нового профиля</TextBlock>
            </StackPanel>
        </Border>

        <!-- Основная форма -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="40,30,40,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Имя -->
                <TextBlock Grid.Row="0" Grid.Column="0" 
                           Text="Имя:" 
                           FontSize="16" FontWeight="SemiBold" 
                           Foreground="#090974" 
                           VerticalAlignment="Center" 
                           Margin="0,10,10,10"/>
                <TextBox Grid.Row="0" Grid.Column="1" 
                         x:Name="Name" 
                         FontSize="14" Height="40" 
                         Padding="10,10"
                         Foreground="#090974" 
                         BorderBrush="#090974" 
                         BorderThickness="1"
                         PreviewTextInput="Name_PreviewTextInput"
                         VerticalAlignment="Center"/>

                <!-- Фамилия -->
                <TextBlock Grid.Row="1" Grid.Column="0" 
                           Text="Фамилия:" 
                           FontSize="16" FontWeight="SemiBold" 
                           Foreground="#090974" 
                           VerticalAlignment="Center" 
                           Margin="0,10,10,10"/>
                <TextBox Grid.Row="1" Grid.Column="1" 
                         x:Name="LastName" 
                         FontSize="14" Height="40" 
                         Padding="10,8"
                         Foreground="#090974" 
                         BorderBrush="#090974" 
                         BorderThickness="1"
                         PreviewTextInput="Name_PreviewTextInput"
                         VerticalAlignment="Center"/>

                <!-- Отчество -->
                <TextBlock Grid.Row="2" Grid.Column="0" 
                           Text="Отчество:" 
                           FontSize="16" FontWeight="SemiBold" 
                           Foreground="#090974" 
                           VerticalAlignment="Center" 
                           Margin="0,10,10,10"/>
                <TextBox Grid.Row="2" Grid.Column="1" 
                         x:Name="Patronymic" 
                         FontSize="14" Height="40" 
                         Padding="10,8"
                         Foreground="#090974" 
                         BorderBrush="#090974" 
                         BorderThickness="1"
                         PreviewTextInput="Name_PreviewTextInput"
                         VerticalAlignment="Center"/>

                <!-- Логин -->
                <TextBlock Grid.Row="3" Grid.Column="0" 
                           Text="Логин:" 
                           FontSize="16" FontWeight="SemiBold" 
                           Foreground="#090974" 
                           VerticalAlignment="Center" 
                           Margin="0,10,10,10"/>
                <TextBox Grid.Row="3" Grid.Column="1" 
                         x:Name="Login" 
                         FontSize="14" Height="40" 
                         Padding="10,8"
                         Foreground="#090974" 
                         BorderBrush="#090974" 
                         BorderThickness="1"
                         PreviewTextInput="Login_PreviewTextInput"
                         VerticalAlignment="Center"/>

                <!-- Пароль -->
                <TextBlock Grid.Row="4" Grid.Column="0" 
                           Text="Пароль:" 
                           FontSize="16" FontWeight="SemiBold" 
                           Foreground="#090974" 
                           VerticalAlignment="Center" 
                           Margin="0,10,10,10"/>
                <PasswordBox Grid.Row="4" Grid.Column="1" 
                             x:Name="PasswordBox" 
                             FontSize="14" Height="40" 
                             Padding="10,8"
                             Foreground="#090974" 
                             BorderBrush="#090974" 
                             BorderThickness="1"
                             VerticalAlignment="Center"/>

                <!-- Тип учетной записи -->
                <TextBlock Grid.Row="5" Grid.Column="0" 
                           Text="Тип учетной записи:" 
                           FontSize="16" FontWeight="SemiBold" 
                           Foreground="#090974" 
                           VerticalAlignment="Center" 
                           Margin="0,10,10,10"/>
                <ComboBox Grid.Row="5" Grid.Column="1" 
                          x:Name="Types" 
                          FontSize="14" Height="40"
                          Foreground="#090974" 
                          BorderBrush="#090974" 
                          BorderThickness="1"
                          SelectionChanged="Types_SelectionChanged"
                          VerticalAlignment="Center"/>

                <!-- Предметы (для учителя) -->
                <TextBlock Grid.Row="6" Grid.Column="0" 
                           x:Name="SubText" 
                           Text="Предметы:" 
                           FontSize="16" FontWeight="SemiBold" 
                           Foreground="#090974" 
                           VerticalAlignment="Center" 
                           Margin="0,10,10,10"
                           Visibility="Collapsed"/>
                <StackPanel Grid.Row="6" Grid.Column="1" 
                            Orientation="Vertical"
                            Visibility="Collapsed"
                            x:Name="SubjectsPanel">
                    <ComboBox x:Name="Subject" 
                              FontSize="14" Height="40"
                              Foreground="#090974" 
                              BorderBrush="#090974" 
                              BorderThickness="1"
                              SelectionChanged="Subject_SelectionChanged"
                              Margin="0,0,0,10"/>
                    <Button x:Name="Add" 
                            Content="Добавить предмет" 
                            Width="200" Height="40"
                            Style="{DynamicResource LongButton}" 
                            local:ButtonStyleExtensions.NormalColor="#3F92D2" 
                            local:ButtonStyleExtensions.HoverColor="#0B61A4" 
                            local:ButtonStyleExtensions.PressedColor="#25567B"
                            Foreground="White" FontSize="14" FontWeight="SemiBold"
                            Click="Add_Click"/>
                    <Button x:Name="newSub" 
                            Content="Новый предмет" 
                            Width="200" Height="40" Margin="0,10,0,0"
                            Style="{StaticResource LongButton}"
                            local:ButtonStyleExtensions.NormalColor="#3F92D2" 
                            local:ButtonStyleExtensions.HoverColor="#0B61A4" 
                            local:ButtonStyleExtensions.PressedColor="#25567B"
                            Foreground="White" FontSize="14" FontWeight="SemiBold"
                            Click="newSub_Click"/>
                </StackPanel>

                <!-- Сообщение об ошибке -->
                <TextBlock Grid.Row="7" Grid.ColumnSpan="2" 
                           x:Name="Error" 
                           FontSize="14" 
                           Margin="0,10,0,0" 
                           Foreground="#D93D0C" 
                           TextAlignment="Center"
                           Text="Все поля должны быть заполнены" 
                           TextWrapping="Wrap" 
                           Visibility="Collapsed"
                           HorizontalAlignment="Center"/>
            </Grid>
        </ScrollViewer>

        <!-- Кнопка сохранения -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Button x:Name="Save" 
                    Width="300" Height="50" 
                    Margin="15,20,15,20"
                    Style="{StaticResource LongButton}"
                    local:ButtonStyleExtensions.NormalColor="#128C58" 
                    local:ButtonStyleExtensions.HoverColor="#47A27B" 
                    local:ButtonStyleExtensions.PressedColor="#36D792"
                    Foreground="White" FontWeight="SemiBold" FontSize="18" 
                    Click="Save_Click"
                    HorizontalAlignment="Center">
                Создать профиль
            </Button>
        </Border>
    </Grid>
</Page>