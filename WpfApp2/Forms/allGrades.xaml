<Page x:Class="WpfApp2.allGrades"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp2"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="900" MinHeight="600" MinWidth="800"
      Title="Итоговые оценки" 
      Loaded="Page_Loaded"
      Background="White">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок страницы -->
        <Border Grid.Row="0" Background="#090974" Height="80" CornerRadius="0,0,20,20">
            <TextBlock Text="Итоговые оценки" 
                       FontSize="24" FontWeight="SemiBold" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Таблица с оценками -->
        <DataGrid x:Name="Grades" Grid.Row="1" Margin="40,30,40,20" Style="{StaticResource DataGridStyle}" 
                  ColumnHeaderStyle="{StaticResource AllText}" AutoGenerateColumns="True" 
                  AutoGeneratingColumn="Grades_AutoGeneratingColumn"
                  CellEditEnding="Grades_CellEditEnding"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  AlternatingRowBackground="#F9F9F9"
                  RowHeight="35"
                  FontSize="14">
        </DataGrid>

        <!-- Нижняя панель с кнопками -->
        <Grid Grid.Row="2" Margin="40,0,40,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель - изменение таблицы -->
            <StackPanel Grid.Column="0" x:Name="ChangeStack" Orientation="Horizontal" 
                        VerticalAlignment="Center" HorizontalAlignment="Left">
                <TextBlock FontFamily="Arial" FontWeight="SemiBold" FontSize="18" 
                           Foreground="#090974" TextAlignment="Center" VerticalAlignment="Center">
                    Изменить таблицу
                </TextBlock>
                <ToggleButton x:Name="IsChange" Height="35" Width="35" 
                              HorizontalAlignment="Center" Margin="15,0,0,0" 
                              Style="{DynamicResource IsChangedStyle}"
                              Click="IsChange_Click">
                </ToggleButton>
            </StackPanel>

            <!-- Правая панель - кнопки управления -->
            <StackPanel Grid.Column="1" x:Name="ButtonsStack" Orientation="Horizontal" 
                        HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="ManageButton" Height="40" Width="200" 
                        Content="Управление предметами" Style="{StaticResource LongButton}" 
                        local:ButtonStyleExtensions.NormalColor="#3F92D2"
                        local:ButtonStyleExtensions.HoverColor="#0B61A4" 
                        local:ButtonStyleExtensions.PressedColor="#25567B"
                        Foreground="White" FontSize="14" FontWeight="SemiBold"
                        Margin="0,0,15,0">
                </Button>
                <Button x:Name="SaveButton" Height="40" Width="150" 
                        Content="Сохранить" Style="{StaticResource LongButton}"
                        local:ButtonStyleExtensions.NormalColor="#128C58" 
                        local:ButtonStyleExtensions.HoverColor="#47A27B" 
                        local:ButtonStyleExtensions.PressedColor="#36D792"
                        Foreground="White" FontWeight="SemiBold" FontSize="14" 
                        Click="SaveButton_Click">
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>